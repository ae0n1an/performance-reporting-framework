# ── Copy this to .env and fill in your values ──
# Never commit .env to source control

# InfluxDB
INFLUX_USER=admin
INFLUX_PASSWORD=changeme123
INFLUX_ORG=perf-org
INFLUX_BUCKET=perf-results
INFLUX_TOKEN=my-super-secret-token   # generate a strong token for prod
INFLUX_RETENTION=8760h               # 1 year; adjust as needed

# PostgreSQL
POSTGRES_USER=perfuser
POSTGRES_PASSWORD=changeme123
POSTGRES_DB=perfdb

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme123
